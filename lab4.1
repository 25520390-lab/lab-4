#include <iostream>
#include <cmath>
using namespace std;

/**
 * Lớp Complex biểu diễn số phức dạng a + bi
 * Hỗ trợ khởi tạo từ số thực (phần ảo = 0)
 * Nạp chồng các phép toán +, -, *, /, ==, !=, <<, >>
 */
class Complex {
private:
    double real, imag;  // phần thực, phần ảo

public:
    // Constructor mặc định & chuyển số thực thành số phức
    Complex(double r = 0, double i = 0) : real(r), imag(i) {}
    // Constructor riêng cho số thực (cũng có thể dùng chung)
    Complex(double r) : real(r), imag(0) {}

    // Toán tử cộng: (a+bi)+(c+di) = (a+c)+(b+d)i
    Complex operator+(const Complex& other) const {
        return Complex(real + other.real, imag + other.imag);
    }

    // Toán tử trừ
    Complex operator-(const Complex& other) const {
        return Complex(real - other.real, imag - other.imag);
    }

    // Toán tử nhân: (a+bi)*(c+di) = (ac-bd)+(ad+bc)i
    Complex operator*(const Complex& other) const {
        return Complex(real * other.real - imag * other.imag,
                       real * other.imag + imag * other.real);
    }

    // Toán tử chia: sử dụng liên hợp
    Complex operator/(const Complex& other) const {
        double denominator = other.real * other.real + other.imag * other.imag;
        if (denominator == 0) {
            cerr << "Loi: chia cho 0!\n";
            return Complex(0,0);
        }
        return Complex((real * other.real + imag * other.imag) / denominator,
                       (imag * other.real - real * other.imag) / denominator);
    }

    // So sánh bằng
    bool operator==(const Complex& other) const {
        return (real == other.real && imag == other.imag);
    }

    // So sánh khác
    bool operator!=(const Complex& other) const {
        return !(*this == other);
    }

    // Nhập số phức từ bàn phím
    friend istream& operator>>(istream& is, Complex& c) {
        cout << "Nhap phan thuc va phan ao: ";
        is >> c.real >> c.imag;
        return is;
    }

    // Xuất số phức dạng a+bi hoặc a-bi
    friend ostream& operator<<(ostream& os, const Complex& c) {
        os << c.real;
        if (c.imag >= 0) os << "+" << c.imag << "i";
        else os << c.imag << "i";
        return os;
    }
};

int main() {
    Complex a(3,4), b(2,-1);
    cout << "a = " << a << ", b = " << b << endl;
    cout << "a + b = " << a+b << endl;
    cout << "a - b = " << a-b << endl;
    cout << "a * b = " << a*b << endl;
    cout << "a / b = " << a/b << endl;
    cout << "a == b? " << (a==b ? "true" : "false") << endl;

    Complex c = 5.0;   // số thực thành số phức
    cout << "So thuc 5.0 -> " << c << endl;
    return 0;
}
